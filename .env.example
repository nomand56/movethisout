# Railway / production build — copy to Railway Variables (or .env locally).
# VITE_* vars are baked in at build time; set them BEFORE deploy builds.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key

# Google Maps — restrict key to your Railway domain + localhost
VITE_GOOGLE_MAPS_KEY=your_google_maps_browser_key

# Web Push (optional)
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key

# Server only (not used by Vite — for setup script if needed)
# SUPABASE_SERVICE_ROLE_KEY=never_commit_this
